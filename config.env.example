# LitSource Monitor Configuration
# Copy this file to ~/.config/litsource-monitor/.env and fill in your API keys

# OpenAI API Key - 用于 Reddit 搜索（推荐）
# 获取: https://platform.openai.com/api-keys
# 费用: ~$0.01-0.05/次搜索
OPENAI_API_KEY=

# xAI API Key - 用于 Twitter/X 搜索（备选）
# 获取: https://console.x.ai/
# 费用: ~$5-10/月
XAI_API_KEY=

# Twitter Cookie Auth - 免费方式，需手动获取
# 方法: 登录 x.com → F12 DevTools → Application → Cookies → x.com
# 复制 auth_token 和 ct0 的值
AUTH_TOKEN=
CT0=
